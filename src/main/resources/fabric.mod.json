{
	"$schema": "https://schemastore.org/fabric.mod",
	"authors": [
		{
			"contact": {
				"GitHub": "$github",
				"Ko-fi": "$kofi",
				"homepage": "$homepage"
			},
			"name": "$developer"
		}
	],
	"contact": {
		"Central": "$central",
		"Modrinth": "$modrinth",
		"issues": "$issue",
		"sources": "$scm"
	},
	"custom": {
		"mc-publish": {
			"curseforge": 1560532,
			"modrinth": "zI606Zwl"
		}
	},
	"depends": {
		"minecraft": "$minecraft"
	},
	"description": "$description",
	"environment": "server",
	"icon": "icon.png",
	"id": "$id",
	"license": "$license",
	"mixins": [
		"mixins.json"
	],
	"name": "$name",
	"version": "$version"
}
